# =====================================================
#  情侶飛行棋 — Docker 部署環境設定
#  複製此檔案為 .env，並填入正確的值
#  cp .env.docker.example .env
# =====================================================

APP_NAME="情侶飛行棋"
APP_ENV=production
# 用此指令產生 Key：docker run --rm flying-chess-online php artisan key:generate --show
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com

# 對外 Port（主機端，container 內部固定 80）
APP_PORT=80

LOG_CHANNEL=stderr
LOG_LEVEL=warning

# SQLite（預設，無需額外設定）
DB_CONNECTION=sqlite

# Session & Cache 使用檔案，避免額外 DB 表需求
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file

# ── Google AdSense（一般網站）──────────────────────
# 留空則不顯示
ADSENSE_PUBLISHER_ID=
ADSENSE_SLOT_HOME_TOP=
ADSENSE_SLOT_HOME_MID=
ADSENSE_SLOT_PLAY=

# ── TrafficJunky（成人網站，優先使用）──────────────
# 前往 trafficjunky.com 申請 Publisher 帳號後填入
# Site ID 和 Spot ID 均可在後台 Manage Zones 找到
TRAFFICJUNKY_SITE_ID=
TRAFFICJUNKY_SPOT_HOME_TOP=
TRAFFICJUNKY_SPOT_HOME_MID=
TRAFFICJUNKY_SPOT_PLAY=
